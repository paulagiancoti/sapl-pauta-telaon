{
  "manifest_version": 3,
  "name": "SAPL Pauta – Telão",
  "version": "1.1.0",
  "description": "Apresenta automaticamente as matérias da pauta da sessão plenária como slideshow para exibição no telão do plenário.",

  "permissions": ["storage", "tabs", "windows"],

  "host_permissions": [
    "https://sapl.suacidade.uf.leg.br/*"
  ],

  "background": { "service_worker": "background.js" },

  "content_scripts": [
    {
      "matches": [
        "https://sapl.suacidade.uf.leg.br/painel-principal/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": { "default_title": "SAPL Pauta – Telão" },

  "web_accessible_resources": [
    {
      "resources": ["display-pauta.html", "display-pauta.js", "logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
